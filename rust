pub fn only_owner(env: &Env, token_id: u32, caller: Address) -> Result<(), Error> {
    let owner: Address = env.storage().instance()
        .get(&DataKey::Owner(token_id))
        .ok_or(Error::TokenNotFound)?;
    
    if owner != caller {
        return Err(Error::Unauthorized);
    }
    
    Ok(())
}